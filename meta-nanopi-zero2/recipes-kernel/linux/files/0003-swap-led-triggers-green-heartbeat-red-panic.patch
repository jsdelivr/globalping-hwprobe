From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yocto Builder <yocto@localhost>
Date: Tue, 10 Dec 2025 00:00:00 +0000
Subject: [PATCH] dts: rk3528: Swap LED triggers - green heartbeat, red panic

Reconfigure LED indicators for more intuitive status feedback:
- sys_led (RED): panic indicator - lights up on kernel panic
- user_led (GREEN): heartbeat - normal operation indicator

This provides clearer visual feedback:
- GREEN blinking = system running normally
- RED solid = kernel panic occurred

Signed-off-by: Yocto Builder <yocto@localhost>
---
 arch/arm64/boot/dts/rockchip/rk3528-nanopi-rev01.dts | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/rockchip/rk3528-nanopi-rev01.dts b/arch/arm64/boot/dts/rockchip/rk3528-nanopi-rev01.dts
index 000000000000..111111111111 100644
--- a/arch/arm64/boot/dts/rockchip/rk3528-nanopi-rev01.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3528-nanopi-rev01.dts
@@ -18,7 +18,7 @@
 		sys_led: led-0 {
 			gpios = <&gpio4 RK_PB0 GPIO_ACTIVE_HIGH>;
 			label = "sys_led";
-			linux,default-trigger = "heartbeat";
+			linux,default-trigger = "panic";
 			pinctrl-names = "default";
 			pinctrl-0 = <&sys_led_pin>;
 		};
@@ -27,6 +27,7 @@
 			gpios = <&gpio4 RK_PB1 GPIO_ACTIVE_HIGH>;
 			label = "user_led";
 			pinctrl-names = "default";
+			linux,default-trigger = "heartbeat";
 			pinctrl-0 = <&user_led_pin>;
 		};
 	};
--
2.34.1
